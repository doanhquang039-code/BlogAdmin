{
  "name": "portfolio-website",
  "version": "1.0.0",
  "description": "Personal Portfolio Website - Đặng Quang Doanh",
  "main": "index.html",
  "private": true,
  "scripts": {
    "dev": "live-server --port=3000 --host=localhost --open=/index.html",
    "start": "live-server --port=8080 --host=0.0.0.0 --open=/index.html",
    "build": "echo 'Building static site...' && npm run minify",
    "minify": "npm run minify:css && npm run minify:js",
    "minify:css": "cleancss -o dist/style.min.css style.css",
    "minify:js": "terser script.js i18n.js -o dist/bundle.min.js --compress --mangle",
    "format": "prettier --write \"*.{html,css,js,json}\"",
    "lint": "eslint \"*.js\"",
    "lint:fix": "eslint \"*.js\" --fix",
    "serve": "http-server -p 8080 -o",
    "docker:build": "docker build -t portfolio-website .",
    "docker:run": "docker run -d -p 8080:80 --name portfolio portfolio-website",
    "docker:stop": "docker stop portfolio && docker rm portfolio",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f"
  },
  "keywords": [
    "portfolio",
    "personal-website",
    "developer-portfolio",
    "static-site",
    "html",
    "css",
    "javascript"
  ],
  "author": {
    "name": "Đặng Quang Doanh",
    "email": "doanhquang039@gmail.com",
    "url": "https://github.com/doanhquang039-code"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doanhquang039-code/portfolio"
  },
  "bugs": {
    "url": "https://github.com/doanhquang039-code/portfolio/issues"
  },
  "homepage": "https://doanhquang039-code.github.io/portfolio",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.8",
    "autoprefixer": "^10.4.19",
    "clean-css-cli": "^5.6.3",
    "eslint": "^8.57.0",
    "http-server": "^14.1.1",
    "live-server": "^1.2.2",
    "prettier": "^3.3.2",
    "terser": "^5.31.1"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
